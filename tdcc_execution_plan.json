{
  "version": "1.0",
  "plan_hash": null,
  "site": "www.tdcc.com.tw",
  "inputs": {
    "stock": { "type": "string", "cli": "--stock" },
    "date":  { "type": "string", "cli": "--date" }
  },
  "steps": [
    {
      "id": "load_page",
      "type": "http_request",
      "session": "default",
      "consumes": [],
      "produces": ["steps.load_page.outputs.html"],
      "request": {
        "method": "GET",
        "url": "https://www.tdcc.com.tw/portal/zh/smWeb/qryStock"
      }
    },
    {
      "id": "extract_csrf",
      "type": "extract_html",
      "session": "default",
      "consumes": ["steps.load_page.outputs.html"],
      "produces": [
        "steps.extract_csrf.outputs.csrf_token",
        "steps.extract_csrf.outputs.fir_date"
      ],
      "from": "{{steps.load_page.outputs.html}}",
      "selectors": {
        "csrf_token": {
          "type": "css",
          "query": "input[name=SYNCHRONIZER_TOKEN]",
          "attr": "value"
        },
        "fir_date": {
          "type": "css",
          "query": "input[name=firDate]",
          "attr": "value"
        }
      }
    },
    {
      "id": "post_query",
      "type": "http_request",
      "session": "default",
      "consumes": [
        "steps.extract_csrf.outputs.csrf_token",
        "steps.extract_csrf.outputs.fir_date"
      ],
      "produces": ["steps.post_query.outputs.html"],
      "request": {
        "method": "POST",
        "url": "https://www.tdcc.com.tw/portal/zh/smWeb/qryStock",
        "payload": {
          "SYNCHRONIZER_TOKEN": "{{steps.extract_csrf.outputs.csrf_token}}",
          "SYNCHRONIZER_URI":   "/portal/zh/smWeb/qryStock",
          "method":             "submit",
          "firDate":            "{{steps.extract_csrf.outputs.fir_date}}",
          "scaDate":            "{{input.date}}",
          "sqlMethod":          "StockNo",
          "stockNo":            "{{input.stock}}"
        }
      }
    },
    {
      "id": "parse_result",
      "type": "parse_table",
      "consumes": ["steps.post_query.outputs.html"],
      "produces": ["steps.parse_result.outputs.rows"],
      "from": "{{steps.post_query.outputs.html}}",
      "selectors": {
        "table": {
          "type": "css",
          "query": "table.table"
        }
      },
      "column_mode": "index",
      "skip_row_keyword": "合　計",
      "add_columns": {
        "日期":    "{{input.date}}",
        "股票代號": "{{input.stock}}"
      }
    },
    {
      "id": "save_output",
      "type": "save_csv",
      "consumes": ["steps.parse_result.outputs.rows"],
      "produces": [],
      "from": "{{steps.parse_result.outputs.rows}}",
      "path": "data/集保_{{input.stock}}_{{input.date}}.csv",
      "encoding": "utf-8-sig"
    }
  ]
}
